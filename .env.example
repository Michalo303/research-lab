# Research-only configuration. Do not put broker or exchange execution keys here.
RESEARCH_LAB_ROOT=/opt/trading/research-lab
RESEARCH_LAB_MODE=research_only
RESEARCH_LAB_DATA_PROVIDER=synthetic
RESEARCH_LAB_ALLOW_SYNTHETIC_FALLBACK=0
RESEARCH_LAB_NETWORK=0
SEC_USER_AGENT=research-lab/0.1-contact@example.com
APIFY_TOKEN=
APIFY_DATAROMA_ACTOR=parsebird/superinvestor-scraper
APIFY_SENTIMENT_ACTOR_ID=
APIFY_REDDIT_ACTOR_ID=
APIFY_STOCKTWITS_ACTOR_ID=
APIFY_NEWS_ACTOR_ID=

# Optional: set to 1 if yfinance is installed and network access is allowed.
RESEARCH_LAB_USE_YFINANCE=0

# EODHD market data. Keep the real key only in .env on the server.
EODHD_API_KEY=
EODHD_START_DATE=1990-01-01

# Massive/Polygon market data fallback. Keep the real key only in .env on the server.
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com
MASSIVE_START_DATE=2021-05-24
MASSIVE_ADJUSTED=true

# Cost assumptions used by the deterministic runner.
RESEARCH_LAB_EOD_COST_BPS=5
RESEARCH_LAB_INTRADAY_COST_BPS=8
RESEARCH_COST_APIFY_DOLLARS_PER_1000_ROWS=2
RESEARCH_COST_MARKET_DATA_DOLLARS_PER_SYMBOL_REFRESH=0
RESEARCH_ALERT_DRAWDOWN_THRESHOLD=-0.15
RESEARCH_ALERT_COST_THRESHOLD_USD=1

# Paper-readiness gates. Keep these conservative unless a review explicitly changes them.
PAPER_GATE_MIN_WF_PASS_RATE=0.67
PAPER_GATE_MAX_DRAWDOWN=-0.15
PAPER_GATE_MIN_LONGTERM_YEARS=10
PAPER_GATE_MIN_ROTATION_YEARS=10
PAPER_GATE_MIN_SWING_YEARS=3
PAPER_GATE_MIN_INTRADAY_YEARS=1
PAPER_GATE_REQUIRE_COST_STRESS=1
PAPER_GATE_MIN_TRADES=100
PAPER_GATE_MIN_REBALANCE_OBSERVATIONS=12
PAPER_GATE_MIN_PORTFOLIO_SCORE=0.01
PAPER_GATE_MIN_PORTFOLIO_WEIGHT_PCT=0.01
PAPER_GATE_MAX_AVG_CORRELATION=0.70
PAPER_GATE_MAX_SINGLE_STRATEGY_WEIGHT_PCT=25

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# IBKR paper execution settings. Passwords and 2FA secrets never belong here.
IBKR_ACCOUNT=
IBKR_MODE=paper
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1
IBKR_READ_ONLY=1
IBKR_CONNECT_TIMEOUT=8
IBKR_MARKET_DATA_TYPE=4
RESEARCH_LAB_ALLOW_PAPER_ORDERS=
IBKR_PAPER_ACCOUNT_ALLOWLIST=

# Local paper order simulator only. This does not send broker orders.
PAPER_ORDER_STRATEGY_ALLOWLIST=
PAPER_ORDER_MAX_NOTIONAL_USD=5000
PAPER_ORDER_SPREAD_BPS=5
PAPER_ORDER_SLIPPAGE_BPS=10
PAPER_ORDER_PARTIAL_FILL_RATIO=1
PAPER_ORDER_LONG_ONLY=1
