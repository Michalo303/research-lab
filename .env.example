# Research-only configuration. Do not put broker or exchange execution keys here.
RESEARCH_LAB_ROOT=/opt/trading/research-lab
RESEARCH_LAB_MODE=research_only
RESEARCH_LAB_DATA_PROVIDER=synthetic

# Optional: set to 1 if yfinance is installed and network access is allowed.
RESEARCH_LAB_USE_YFINANCE=0

# Massive/Polygon market data. Keep the real key only in .env on the server.
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com
MASSIVE_START_DATE=2021-05-24
MASSIVE_ADJUSTED=true

# Cost assumptions used by the deterministic runner.
RESEARCH_LAB_EOD_COST_BPS=5
RESEARCH_LAB_INTRADAY_COST_BPS=8
