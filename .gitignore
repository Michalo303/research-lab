# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Local configuration
.env
APPROVED_FOR_PAPER_IBKR_ORDERS.md
APPROVED_FOR_LIVE_IBKR.md

# Large or replaceable market data
data/raw/*
data/processed/*
data/manifests/*

# Preserve empty data dirs in git.
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/manifests/.gitkeep

# Generated caches and local logs
*.log

# Local runtime state
tmp/
backtests/runs/
reports/
registry/source_items.jsonl
registry/*.lock
registry/*.jsonl
registry/*.csv

# EODHD runtime smoke-test artifacts
registry/eodhd_coverage_report.csv
registry/eodhd_vendor_report.json

# Local inventory/deployment artifacts
INVENTORY_*
deploy*.zip

# Private Hermes library and curated notes must remain outside git.
**/hermes_books/raw/
**/hermes_books/index/
**/hermes_books/text/
**/hermes_books/passage_candidates/
**/hermes_books/proposed_notes/
**/hermes_books/extracted_notes/
**/hermes_books/feedback/
**/hermes_books/**/*.pdf
