{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tradebot2.local/hermes/knowledge-entry.schema.json",
  "title": "Hermes Curated Book-Inspired Hypothesis Seed",
  "description": "A short, testable paraphrase with provenance; not source-book text storage.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "book_id",
    "source_title",
    "source_path",
    "source_sha256",
    "concept",
    "hypothesis",
    "summary",
    "testable_rules",
    "compatible_builders",
    "asset_classes",
    "timeframes",
    "expected_edge",
    "known_failure_modes",
    "addresses_blockers",
    "priority_score"
  ],
  "properties": {
    "book_id": {"type": "string", "pattern": "^book-[0-9a-fA-F]{12}$"},
    "source_title": {"type": "string", "minLength": 1, "maxLength": 300},
    "source_path": {"type": "string", "minLength": 1, "maxLength": 1000},
    "source_sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
    "concept": {"type": "string", "minLength": 1, "maxLength": 200},
    "hypothesis": {"type": "string", "minLength": 1, "maxLength": 500},
    "summary": {"type": "string", "minLength": 1, "maxLength": 600},
    "source_excerpt": {"type": "string", "maxLength": 280},
    "testable_rules": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {"type": "string", "minLength": 1, "maxLength": 300}
    },
    "compatible_builders": {"type": "array", "minItems": 1, "maxItems": 12, "items": {"type": "string", "minLength": 1, "maxLength": 100}},
    "asset_classes": {"type": "array", "minItems": 1, "maxItems": 12, "items": {"type": "string", "minLength": 1, "maxLength": 100}},
    "timeframes": {"type": "array", "minItems": 1, "maxItems": 12, "items": {"type": "string", "minLength": 1, "maxLength": 50}},
    "expected_edge": {"type": "string", "minLength": 1, "maxLength": 400},
    "known_failure_modes": {"type": "array", "minItems": 1, "maxItems": 12, "items": {"type": "string", "minLength": 1, "maxLength": 300}},
    "addresses_blockers": {"type": "array", "minItems": 1, "maxItems": 12, "items": {"type": "string", "minLength": 1, "maxLength": 100}},
    "priority_score": {"type": "number", "minimum": 0, "maximum": 100}
  }
}
